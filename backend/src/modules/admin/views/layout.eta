<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= it.title %> · Roots & Rings Admin</title>
<style>
  :root{--bone:#fef9f1;--ink:#1d1c17;--muted:#4d4540;--line:rgba(140,131,120,.3);--clay:#875134;--celadon:#dae6d5;--err:#ba1a1a;--surface:#f8f3eb;}
  *{box-sizing:border-box}
  body{margin:0;font-family:Inter,system-ui,sans-serif;background:var(--bone);color:var(--ink);font-size:14px;line-height:1.5}
  a{color:inherit}
  .app{display:flex;min-height:100vh}
  aside{width:220px;background:var(--ink);color:var(--bone);display:flex;flex-direction:column;flex-shrink:0}
  aside .brand{font-family:Georgia,'EB Garamond',serif;font-size:20px;letter-spacing:.02em;padding:22px 20px;border-bottom:1px solid rgba(255,255,255,.1)}
  aside nav{display:flex;flex-direction:column;padding:12px 0;flex:1}
  aside nav a{padding:11px 20px;text-decoration:none;opacity:.7;font-size:12px;letter-spacing:.12em;text-transform:uppercase}
  aside nav a:hover{opacity:1;background:rgba(255,255,255,.05)}
  aside nav a.active{opacity:1;border-left:2px solid var(--clay)}
  aside .foot{padding:16px 20px;border-top:1px solid rgba(255,255,255,.1);font-size:12px}
  aside .foot button{background:none;border:1px solid rgba(255,255,255,.3);color:var(--bone);padding:8px 12px;cursor:pointer;width:100%;text-transform:uppercase;letter-spacing:.1em;font-size:11px}
  main{flex:1;padding:32px 40px;max-width:1100px}
  h1{font-family:Georgia,'EB Garamond',serif;font-weight:400;font-size:30px;margin:0 0 6px}
  h2{font-family:Georgia,'EB Garamond',serif;font-weight:400;font-size:22px}
  .sub{color:var(--muted);margin:0 0 28px}
  .flash{padding:12px 16px;margin-bottom:20px;border:1px solid var(--line)}
  .flash.error{border-color:var(--err);color:var(--err);background:#ffecea}
  .flash.success{border-color:#3f4a3d;background:var(--celadon)}
  table{width:100%;border-collapse:collapse;background:#fff;border:1px solid var(--line)}
  th,td{text-align:left;padding:11px 14px;border-bottom:1px solid var(--line);vertical-align:middle}
  th{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  tr:last-child td{border-bottom:none}
  .btn{display:inline-block;background:var(--ink);color:var(--bone);padding:10px 18px;border:1px solid var(--ink);text-decoration:none;cursor:pointer;font-size:11px;letter-spacing:.12em;text-transform:uppercase}
  .btn.ghost{background:transparent;color:var(--ink);border-color:var(--muted)}
  .btn.danger{background:var(--err);border-color:var(--err)}
  .btn.sm{padding:6px 12px;font-size:10px}
  .row{display:flex;gap:24px;flex-wrap:wrap}
  .card{background:#fff;border:1px solid var(--line);padding:20px;flex:1;min-width:160px}
  .card .n{font-family:Georgia,serif;font-size:34px}
  .card .l{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  form.stack{display:flex;flex-direction:column;gap:16px;max-width:640px;background:#fff;border:1px solid var(--line);padding:24px}
  label{display:flex;flex-direction:column;gap:6px;font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted)}
  input,select,textarea{font:inherit;padding:10px 12px;border:1px solid var(--line);background:var(--bone);color:var(--ink);border-radius:0}
  textarea{min-height:90px;resize:vertical}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .actions{display:flex;gap:12px;align-items:center;margin-top:8px}
  .thumb{width:48px;height:60px;object-fit:cover;background:var(--surface)}
  .pill{display:inline-block;background:var(--celadon);color:#3f4a3d;padding:3px 8px;font-size:10px;letter-spacing:.08em;text-transform:uppercase}
  .muted{color:var(--muted)}
  .imgrow{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
  .imgrow figure{margin:0;border:1px solid var(--line);padding:6px;background:#fff;width:110px}
  .imgrow img{width:100%;height:120px;object-fit:cover}
  .toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;gap:16px}
</style>
</head>
<body>
<div class="app">
  <% if (it.user) { %>
  <aside>
    <div class="brand">ROOTS &amp; RINGS</div>
    <nav>
      <a href="/admin" class="<%= it.active==='dashboard'?'active':'' %>">Dashboard</a>
      <a href="/admin/analytics" class="<%= it.active==='analytics'?'active':'' %>">Analytics</a>
      <a href="/admin/products" class="<%= it.active==='products'?'active':'' %>">Products</a>
      <a href="/admin/orders" class="<%= it.active==='orders'?'active':'' %>">Orders</a>
      <a href="/admin/coupons" class="<%= it.active==='coupons'?'active':'' %>">Coupons</a>
      <a href="/admin/reviews" class="<%= it.active==='reviews'?'active':'' %>">Reviews</a>
      <a href="/admin/categories" class="<%= it.active==='categories'?'active':'' %>">Categories</a>
      <a href="/admin/team" class="<%= it.active==='team'?'active':'' %>">Team</a>
      <a href="<%= it.storefront || 'http://localhost:4321' %>" target="_blank">View Site ↗</a>
    </nav>
    <div class="foot">
      <div class="muted" style="margin-bottom:10px"><%= it.user.name %><br><%= it.user.role %></div>
      <form method="post" action="/admin/logout">
        <input type="hidden" name="_csrf" value="<%= it.csrf %>" />
        <button type="submit">Sign out</button>
      </form>
    </div>
  </aside>
  <% } %>
  <main>
    <% if (it.flash) { %><div class="flash <%= it.flash.type %>"><%= it.flash.message %></div><% } %>
    <%~ it.body %>
  </main>
</div>
</body>
</html>
