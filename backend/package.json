{
  "name": "roots-and-rings-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Roots & Rings — Fastify e-commerce backend (API + admin)",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "start": "node --env-file=.env --import tsx src/server.ts",
    "test": "vitest run",
    "prisma": "prisma",
    "seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "create-admin": "node --env-file=.env --import tsx src/scripts/create-admin.ts"
  },
  "prisma": {
    "seed": "node --env-file=.env --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/csrf-protection": "^7.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@fastify/view": "^10.0.1",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "eta": "^3.5.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.9",
    "nodemailer": "^9.0.3",
    "sanitize-html": "^2.13.1",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/sanitize-html": "^2.13.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
