generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum CategoryKind {
  PRODUCT_TYPE
  COLLECTION
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AdminAuditLog[]

  @@index([role])
  @@index([isActive])
}

model Category {
  id            String       @id @default(cuid())
  kind          CategoryKind @default(PRODUCT_TYPE)
  name          String
  slug          String       @unique
  tagline       String?
  description    String?      @db.Text
  imageUrl      String?
  sortOrder     Int          @default(0)
  isActive      Boolean      @default(true)
  seoTitle      String?
  seoDescription String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  // Products whose primary product-type is this category
  typeProducts Product[] @relation("ProductType")
  // Products tagged into this collection (M:N)
  collectionProducts Product[] @relation("ProductCollections")

  @@index([kind])
  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Product {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  sku              String    @unique
  subtitle         String?
  shortDescription String    @db.Text
  description      String    @db.Text
  clayBody         String?
  badges           Json      @default("[]")
  basePrice        Decimal   @db.Decimal(12, 2)
  salePrice        Decimal?  @db.Decimal(12, 2)
  flashPrice       Decimal?  @db.Decimal(12, 2)
  flashStartAt     DateTime?
  flashEndAt       DateTime?
  currency         String    @default("BDT")
  isActive         Boolean   @default(true)
  isFeatured       Boolean   @default(false)
  featuredOrder    Int?
  allowBackorder   Boolean   @default(false)
  minPerOrder      Int       @default(1)
  maxPerOrder      Int?
  specs            Json      @default("{}")
  edition          Json?
  curatorsNote     String?   @db.Text
  seenInInteriors  Json?
  seoTitle         String?
  seoDescription   String?   @db.Text
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  categoryId String?
  category   Category? @relation("ProductType", fields: [categoryId], references: [id], onDelete: SetNull)

  collections Category[]       @relation("ProductCollections")
  variants    ProductVariant[]
  images      ProductImage[]
  ratingAvg   Decimal?         @db.Decimal(3, 2)
  ratingCount Int              @default(0)
  reviews     Review[]
  wishlistedBy WishlistItem[]

  @@index([isActive])
  @@index([isFeatured, featuredOrder])
  @@index([basePrice])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([flashEndAt])
  @@index([categoryId])
  @@fulltext([name, shortDescription])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String   @unique
  name              String
  size              String?
  color             String?
  price             Decimal? @db.Decimal(12, 2)
  salePrice         Decimal? @db.Decimal(12, 2)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(0)
  weight            Float?
  barcode           String?
  position          Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  images                ProductImage[]
  movements             InventoryMovement[]
  reservations          InventoryReservation[]
  lowStockNotifications LowStockNotification[]

  @@index([productId, isActive])
  @@index([stock])
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  url       String
  alt       String?
  width     Int?
  height    Int?
  position  Int             @default(0)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@index([productId, position])
  @@index([variantId])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String
  action      String
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ===== Phase 2: orders, inventory, payments =====

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_REVIEW
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProviderKind {
  COD
  BKASH
  MANUAL
}

enum OrderSource {
  WEBSITE
  FACEBOOK
  INSTAGRAM
  OTHER
}

enum PaymentStatus {
  INITIATED
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReservationStatus {
  ACTIVE
  COMMITTED
  RELEASED
  EXPIRED
}

enum MovementType {
  MANUAL_ADJUSTMENT
  SALE
  RESERVATION
  RESERVATION_RELEASE
  RESERVATION_EXPIRY
  REFUND_RESTOCK
  CANCELLATION_RESTOCK
}

enum ShipmentStatus {
  PENDING
  PACKED
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model InventoryMovement {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type      MovementType
  quantity  Int
  reason    String?
  orderId   String?
  createdAt DateTime       @default(now())

  @@index([variantId])
  @@index([orderId])
  @@index([createdAt])
}

model InventoryReservation {
  id        String            @id @default(cuid())
  variantId String
  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId   String
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([variantId, status])
  @@index([orderId])
  @@index([status, expiresAt])
}

model LowStockNotification {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  threshold  Int
  notifiedAt DateTime?
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([variantId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String?
  guestEmail      String
  guestPhone      String?
  status          OrderStatus @default(AWAITING_PAYMENT)
  source          OrderSource @default(WEBSITE)
  currency        String      @default("BDT")
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(12, 2)
  shippingTotal   Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal     @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal     @db.Decimal(12, 2)
  idempotencyKey  String      @unique
  couponCode       String?
  orderToken      String      @unique
  shippingSnapshot Json
  placedAt        DateTime    @default(now())
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items     OrderItem[]
  payments  Payment[]
  shipment  Shipment?

  @@index([status])
  @@index([createdAt])
  @@index([guestEmail])
  @@index([source])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  variantId   String?
  productName String
  variantName String?
  sku         String
  unitPrice   Decimal @db.Decimal(12, 2)
  quantity    Int
  lineTotal   Decimal @db.Decimal(12, 2)

  @@index([orderId])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         ShipmentStatus @default(PENDING)
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Payment {
  id            String              @id @default(cuid())
  orderId       String
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      PaymentProviderKind
  status        PaymentStatus       @default(INITIATED)
  amount        Decimal             @db.Decimal(12, 2)
  currency      String              @default("BDT")
  tranId        String              @unique
  bkashPaymentID String?            @unique
  bkashTrxID    String?
  payerMasked   String?
  gatewayPageURL String?
  validatedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  events PaymentEvent[]

  @@index([orderId])
  @@index([status])
}

model PaymentEvent {
  id             String   @id @default(cuid())
  paymentId      String
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type           String
  rawPayload     Json
  signatureValid Boolean  @default(true)
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([paymentId])
  @@index([type])
}

model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  runAt       DateTime  @default(now())
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  lastError   String?   @db.Text
  lockedAt    DateTime?
  lockedBy    String?
  createdAt   DateTime  @default(now())

  @@index([status, runAt])
}

// ===== Phase 3: customer accounts =====

enum OtpType {
  EMAIL_VERIFY
  PASSWORD_RESET
  PASSWORD_CHANGE
}

enum AddressType {
  SHIPPING
  BILLING
}

model Customer {
  id              String        @id @default(cuid())
  email           String        @unique
  passwordHash    String?
  name            String
  phone           String?
  imageUrl        String?
  googleId        String?       @unique
  emailVerifiedAt DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  otps            CustomerOtp[]
  addresses       Address[]
  reviews         Review[]
  wishlist        WishlistItem[]
}

model CustomerOtp {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       OtpType
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([customerId, type])
  @@index([expiresAt])
}

model Address {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       AddressType @default(SHIPPING)
  isDefault  Boolean     @default(false)
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  district   String
  postalCode String?
  country    String      @default("Bangladesh")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([customerId])
}

// ===== Phase 4: coupons =====

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id               String             @id @default(cuid())
  code             String             @unique
  description      String?
  type             CouponType
  value            Decimal            @db.Decimal(12, 2)
  minOrderSubtotal Decimal            @default(0) @db.Decimal(12, 2)
  maxRedemptions   Int?
  perCustomerLimit Int?
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean            @default(true)
  timesRedeemed    Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  redemptions      CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId    String
  customerId String?
  email      String
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@index([couponId])
  @@index([couponId, customerId])
  @@index([couponId, email])
}

// ===== Phase 5: reviews =====

enum ReviewStatus {
  PUBLISHED
  HIDDEN
}

model Review {
  id         String       @id @default(cuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int
  title      String?
  body       String?      @db.Text
  authorName String
  status     ReviewStatus @default(PUBLISHED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([productId, customerId])
  @@index([productId, status])
  @@index([customerId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
}
