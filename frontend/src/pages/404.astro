---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" noindex={true}>
  <section class="wrap min-h-[60vh] flex flex-col items-center justify-center text-center py-section-gap fade-up">
    <span class="text-label-caps uppercase opacity-60 mb-6">Error 404</span>
    <h1 class="font-display text-display-mobile md:text-display-lg italic max-w-2xl leading-[1.1]">
      This page has not yet been thrown.
    </h1>
    <p class="text-body-lg text-on-surface-variant mt-8 max-w-md">
      The page you’re looking for can’t be found. Let’s return you to the objects.
    </p>
    <a href="/" class="btn-solid mt-10">Return Home</a>
  </section>
</BaseLayout>
