---
import { buildCartLookup, lookupToJson } from '../../lib/cart-lookup';
import Icon from '../ui/Icon.astro';

/**
 * Global slide-in cart drawer. Builds a slug → product lookup (with an optimised
 * thumbnail URL) at build time and embeds it as JSON; cart-drawer.ts renders line
 * items reactively from the $cart store.
 */
const lookupJson = lookupToJson(await buildCartLookup());
---

<div id="cart-overlay" class="cart-overlay fixed inset-0 z-[60] bg-on-surface/30" aria-hidden="true"></div>

<aside
  id="cart-drawer"
  class="cart-drawer fixed top-0 right-0 z-[70] h-full w-full max-w-[420px] bg-surface flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping bag"
  aria-hidden="true"
>
  <div class="flex items-center justify-between px-6 py-5 hairline-b">
    <h2 class="font-display text-headline-sm" data-cart-title>Your Bag</h2>
    <button type="button" data-cart-close aria-label="Close bag" class="opacity-70 hover:opacity-100 transition-opacity">
      <Icon name="close" size={22} />
    </button>
  </div>

  <div data-cart-items class="flex-1 overflow-y-auto px-6"></div>

  <div data-cart-empty hidden class="flex-1 flex flex-col items-center justify-center text-center px-6 gap-6">
    <p class="text-body-md text-on-surface-variant">Your bag is empty.</p>
    <a href="/products" data-cart-close class="btn-editorial text-label-caps uppercase">Browse Products</a>
  </div>

  <div data-cart-footer hidden class="px-6 py-6 hairline-t flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <span class="text-label-caps uppercase opacity-60">Subtotal</span>
      <span class="font-display text-headline-sm" data-cart-subtotal>€0</span>
    </div>
    <p class="text-caption text-on-surface-variant">Shipping &amp; taxes calculated at checkout.</p>
    <a href="/checkout" class="btn-solid w-full">Proceed to Checkout</a>
    <button type="button" data-cart-close class="btn-editorial text-label-caps uppercase mx-auto">Continue Shopping</button>
  </div>

  <script type="application/json" data-cart-lookup set:html={lookupJson}></script>
</aside>

<style>
  .cart-overlay {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease-gallery), visibility 0s linear 0.4s;
  }
  .cart-overlay.open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s var(--ease-gallery);
  }
  .cart-drawer {
    transform: translateX(100%);
    transition: transform 0.45s var(--ease-gallery);
  }
  .cart-drawer.open {
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .cart-overlay,
    .cart-drawer {
      transition: none;
    }
  }
</style>
