---
/**
 * Section heading: optional label-caps eyebrow over an EB Garamond title.
 */
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, align = 'center', class: className = '' } = Astro.props;
const alignment = align === 'center' ? 'items-center text-center' : 'items-start text-left';
---

<div class={`flex flex-col ${alignment} ${className}`}>
  {eyebrow && (
    <span class="text-label-caps uppercase text-on-surface-variant opacity-70 mb-6">{eyebrow}</span>
  )}
  <h2 class="font-display text-headline-md text-on-surface">{title}</h2>
</div>
