---
import { footerNav, minimalFooterNav } from '../../data/navigation';
import { site } from '../../data/site';
import Newsletter from './Newsletter.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  variant?: 'minimal' | 'full';
}
const { variant = 'full' } = Astro.props;
const year = 2026;
---

{variant === 'minimal' ? (
  <footer class="hairline-t pt-24 pb-12 fade-up">
    <div class="wrap flex flex-col items-center text-center">
      <a href="/" class="font-display text-headline-md tracking-tight mb-14 hover:opacity-70 transition-opacity">
        {site.name.toUpperCase()}
      </a>
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4 mb-16 text-label-caps uppercase opacity-60">
        {minimalFooterNav.map((l) => (
          <a href={l.href} class="hover:opacity-100 transition-opacity">{l.label}</a>
        ))}
      </div>
      <p class="text-caption opacity-40">{`© ${year} ${site.name}. Handcrafted in small batches.`}</p>
    </div>
  </footer>
) : (
  <footer class="hairline-t pt-20 pb-12">
    <div class="wrap grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-gutter">
      <div class="md:col-span-4">
        <a href="/" class="font-display text-headline-md tracking-tight hover:opacity-70 transition-opacity">
          {site.name.toUpperCase()}
        </a>
        <p class="text-caption text-on-surface-variant mt-4 max-w-xs italic">{site.tagline}</p>
      </div>

      {footerNav.map((col) => (
        <div class="md:col-span-2">
          <h3 class="font-body text-label-caps uppercase opacity-60 mb-5">{col.heading}</h3>
          <ul class="flex flex-col gap-3 text-body-md text-on-surface-variant">
            {col.links.map((l) => (
              <li><a href={l.href} class="hover:text-on-surface transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <div class="md:col-span-4">
        <Newsletter />
      </div>
    </div>

    <div class="wrap mt-16 pt-8 hairline-t flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-caption opacity-40">{`© ${year} ${site.name}. Handcrafted in small batches.`}</p>
      <div class="flex items-center gap-5">
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="opacity-50 hover:opacity-100 transition-opacity">
          <Icon name="instagram" size={18} />
        </a>
        <a href={site.social.pinterest} target="_blank" rel="noopener" aria-label="Pinterest" class="opacity-50 hover:opacity-100 transition-opacity">
          <Icon name="pinterest" size={18} />
        </a>
      </div>
    </div>
  </footer>
)}
